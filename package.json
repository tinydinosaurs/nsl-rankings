{
	"name": "nsl-rankings",
	"version": "0.4.1",
	"private": true,
	"workspaces": [
		"client",
		"server"
	],
	"scripts": {
		"dev": "concurrently --kill-others --kill-others-on-fail --handle-input \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
		"install:all": "npm install && npm install --workspace=client && npm install --workspace=server",
		"test": "npm run test --workspace=server && npm run test --workspace=client",
		"test:server": "npm run test --workspace=server",
		"test:client": "npm run test --workspace=client",
		"lint": "npm run lint --workspace=server && npm run lint --workspace=client",
		"format": "prettier --write --ignore-path .prettierignore .",
		"build": "npm run build --workspace=client",
		"preview": "npm run preview --workspace=client",
		"start": "node server/index.js",
		"seed:reset": "npm run --workspace=server seed:reset"
	},
	"devDependencies": {
		"concurrently": "^8.2.2"
	}
}
